// prisma/schema.prisma

generator client {
  provider = "prisma-client-py"
  interface = "asyncio"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  USER
  ADMIN
}

model User {
  id         Int         @id @default(autoincrement())
  username   String      @unique
  email      String      @unique
  password   String?
  rawPassword String?    @default("") 
  isVerified Boolean     @default(false)
  verificationOTP String?
  otpExpiry  DateTime?
  googleId   String?     @unique
  facebookId String?     @unique
  microsoftId String?    @unique
  authProvider String    @default("local")
  role       Role        @default(USER)
  isBanned   Boolean     @default(false)
  createdAt  DateTime    @default(now())
  tempEmails TempEmail[]
}

model TempEmail {
  id            Int       @id @default(autoincrement())
  email         String    @unique
  createdAt     DateTime  @default(now())
  expiresAt     DateTime
  isActive      Boolean   @default(true)
  
  // Synthetic Persona Generator Fields
  personaName   String?
  personaJob    String?
  personaBio    String?
  personaAvatar String?
  
  // Camouflage Mode (Bypasses site-side bot detectors)
  camouflageEnabled Boolean @default(false)
  
  userId        Int?
  user          User?     @relation(fields: [userId], references: [id], onDelete: Cascade)
  messages      Message[]
  otps          OTP[]

  @@index([userId, isActive])
  @@index([email])
}

model Message {
  id              Int       @id @default(autoincrement())
  tempEmailId     Int
  tempEmail       TempEmail @relation(fields: [tempEmailId], references: [id], onDelete: Cascade)
  sender          String
  subject         String
  body            String    @db.Text
  otpCode         String?
  verificationLink String?
  
  // Privacy Shield (De-tracker) Meta
  trackersBlocked Int       @default(0)
  
  receivedAt      DateTime  @default(now())

  @@index([tempEmailId, receivedAt])
}

model OTP {
  id          Int       @id @default(autoincrement())
  tempEmailId Int
  tempEmail   TempEmail @relation(fields: [tempEmailId], references: [id], onDelete: Cascade)
  code        String
  createdAt   DateTime  @default(now())
  isUsed      Boolean   @default(false)
}

model VisitorLog {
  id        Int      @id @default(autoincrement())
  ip        String
  userAgent String?
  path      String?
  timestamp DateTime @default(now())

  @@index([timestamp])
}